{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Run FastAPI Backend",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "▶ Train ML Models",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/ml/train_model.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "▶ Generate Dataset",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/data/generate_dataset.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": ["▶ Run FastAPI Backend"]
    }
  ]
}
